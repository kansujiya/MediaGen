# Copy to .env and fill in. .env is gitignored.

# Ollama server (default localhost). Pull a model first: `ollama pull qwen2.5:7b`
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# Hugging Face token (only needed for gated models, e.g. some Wan/Hunyuan checkpoints)
HF_TOKEN=

# Output dirs (relative to repo root unless absolute)
OUTPUT_DIR=output
WORKSPACE_DIR=workspace

# YouTube OAuth (place client_secret.json in credentials/)
YT_CLIENT_SECRETS=credentials/client_secret.json
YT_TOKEN_FILE=credentials/yt_token.json
YT_DEFAULT_PRIVACY=private   # private | unlisted | public
